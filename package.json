{
  "name": "perp-orchestrator",
  "version": "1.0.0",
  "description": "MCP server for Perplexity AI search, webhook alerts, and tunnel management",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http",
    "test": "jest",
    "test:watch": "jest --watch",
    "start:poller": "node dist/cascade-poller.js",
    "start:identity": "node dist/cascade-identity.js",
    "start:orchestrator": "node dist/ds-inject-orchestrator.js",
    "start:orchestrator:dry": "node dist/ds-inject-orchestrator.js --dry-run",
    "start:dashboard": "node dist/ds-inject-dashboard.js",
    "ds:once": "node dist/ds-inject-orchestrator.js --once",
    "ds:once:dry": "node dist/ds-inject-orchestrator.js --dry-run --once",
    "test:template": "npx tsx test/ds-inject/template-v1.test.ts",
    "test:cycle": "npx tsx test/ds-inject/inject-cycle.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  }
}
